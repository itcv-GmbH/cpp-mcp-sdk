@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

set(mcp_sdk_ENABLE_TLS "@MCP_SDK_ENABLE_TLS@")
set(mcp_sdk_ENABLE_AUTH "@MCP_SDK_ENABLE_AUTH@")

get_filename_component(_mcp_sdk_prefix "${CMAKE_CURRENT_LIST_DIR}/../../.." ABSOLUTE)
file(GLOB _mcp_sdk_vcpkg_triplets "${_mcp_sdk_prefix}/../vcpkg-*/vcpkg_installed/*")
foreach(_mcp_sdk_triplet_dir IN LISTS _mcp_sdk_vcpkg_triplets)
  if(IS_DIRECTORY "${_mcp_sdk_triplet_dir}")
    list(APPEND CMAKE_PREFIX_PATH "${_mcp_sdk_triplet_dir}")
  endif()
endforeach()

find_dependency(jsoncons CONFIG REQUIRED)
find_dependency(boost_asio CONFIG REQUIRED)
find_dependency(boost_beast CONFIG REQUIRED)

if(@MCP_SDK_USES_BOOST_PROCESS@)
  find_dependency(boost_process CONFIG REQUIRED)
endif()

if(@MCP_SDK_REQUIRES_OPENSSL@)
  find_dependency(OpenSSL REQUIRED)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/mcp_sdkTargets.cmake")

check_required_components(mcp_sdk)
