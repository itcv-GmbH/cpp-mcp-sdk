{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 16,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "vcpkg-base",
      "hidden": true,
      "inherits": "base",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "VCPKG_MANIFEST_MODE": "ON"
      }
    },
    {
      "name": "unix-release",
      "inherits": "base",
      "displayName": "Unix Release",
      "description": "Release build for Unix-like systems",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      },
      "condition": {
        "type": "not",
        "condition": {
          "type": "equals",
          "lhs": "${hostSystemName}",
          "rhs": "Windows"
        }
      }
    },
    {
      "name": "unix-debug",
      "inherits": "base",
      "displayName": "Unix Debug",
      "description": "Debug build for Unix-like systems",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      },
      "condition": {
        "type": "not",
        "condition": {
          "type": "equals",
          "lhs": "${hostSystemName}",
          "rhs": "Windows"
        }
      }
    },
    {
      "name": "vcpkg-unix-release",
      "inherits": ["vcpkg-base"],
      "displayName": "vcpkg Unix Release",
      "description": "Release build with vcpkg for Unix-like systems",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      },
      "condition": {
        "type": "not",
        "condition": {
          "type": "equals",
          "lhs": "${hostSystemName}",
          "rhs": "Windows"
        }
      }
    },
    {
      "name": "windows-release",
      "inherits": "base",
      "displayName": "Windows Release",
      "description": "Release build for Windows with multi-config support",
      "architecture": "x64",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "windows-debug",
      "inherits": "base",
      "displayName": "Windows Debug",
      "description": "Debug build for Windows with multi-config support",
      "architecture": "x64",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "vcpkg-windows-release",
      "inherits": ["vcpkg-base"],
      "displayName": "vcpkg Windows Release",
      "description": "Release build with vcpkg for Windows",
      "architecture": "x64",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "unix-release",
      "configurePreset": "unix-release"
    },
    {
      "name": "unix-debug",
      "configurePreset": "unix-debug"
    },
    {
      "name": "vcpkg-unix-release",
      "configurePreset": "vcpkg-unix-release"
    },
    {
      "name": "windows-release",
      "configurePreset": "windows-release",
      "configuration": "Release"
    },
    {
      "name": "windows-debug",
      "configurePreset": "windows-debug",
      "configuration": "Debug"
    },
    {
      "name": "vcpkg-windows-release",
      "configurePreset": "vcpkg-windows-release",
      "configuration": "Release"
    }
  ],
  "testPresets": [
    {
      "name": "unix-release",
      "configurePreset": "unix-release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "unix-debug",
      "configurePreset": "unix-debug",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
