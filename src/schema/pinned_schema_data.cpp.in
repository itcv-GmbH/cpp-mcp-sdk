#include <string_view>

#include <mcp/schema/pinned_schema.hpp>

namespace mcp::schema::detail
{

auto pinnedSchemaJson() -> std::string_view
{
  return R"__mcp_schema__(
@MCP_SDK_PINNED_MCP_SCHEMA_JSON@
)__mcp_schema__";
}

auto pinnedSchemaSourcePath() -> std::string_view
{
  return "@MCP_SDK_PINNED_MCP_SCHEMA_FILE@";
}

}  // namespace mcp::schema::detail
